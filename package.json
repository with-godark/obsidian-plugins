{
  "name": "obsidian-plugins",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:theme": "pnpm --filter @godark/terminal-theme build",
    "clean": "pnpm -r clean",
    "dev:theme": "pnpm --filter @godark/terminal-theme dev",
    "dev:theme:sync": "pnpm --filter @godark/terminal-theme dev:sync",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm run lint:js && pnpm run lint:css && pnpm run format:check",
    "lint:css": "stylelint \"packages/**/*.css\" --allow-empty-input",
    "lint:js": "eslint .",
    "sync:theme": "pnpm --filter @godark/terminal-theme sync"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "chokidar": "^4.0.3",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.0",
    "prettier": "^3.5.3",
    "stylelint": "^16.16.0",
    "stylelint-config-standard": "^38.0.0"
  }
}
